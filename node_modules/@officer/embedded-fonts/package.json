  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --check --cache --ignore-path .gitignore '**/*.{js,jsx,ts,tsx,json,css,scss,md}'",
