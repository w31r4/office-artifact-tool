{
  "name": "office-artifact-tool",
  "version": "2.8.31",
  "description": "Standalone Office artifact toolkit package.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w31r4/office-artifact-tool.git"
  },
  "bugs": {
    "url": "https://github.com/w31r4/office-artifact-tool/issues"
  },
  "homepage": "https://github.com/w31r4/office-artifact-tool#readme",
  "dependencies": {
    "@officer/embedded-fonts": "0.1.1",
    "skia-canvas": "3.0.8",
    "@officer/walnut": "0.1.231"
  },
  "exports": {
    ".": "./dist/artifact_tool.mjs",
    "./presentation-jsx": "./dist/presentation-jsx/index.mjs",
    "./presentation-jsx/jsx-runtime": "./dist/presentation-jsx/jsx-runtime.mjs",
    "./presentation-jsx/jsx-dev-runtime": "./dist/presentation-jsx/jsx-dev-runtime.mjs"
  },
  "files": [
    "dist/**",
    "node_modules/**",
    "LICENSE.md",
    "NOTICE.md",
    "README.md",
    "test/**"
  ],
  "scripts": {
    "test": "node test/import-smoke.mjs && node test/package-contents-smoke.mjs && node test/presentation-export-smoke.mjs && node test/template-library-smoke.mjs && node test/template-creator-smoke.mjs && node test/default-template-library-smoke.mjs",
    "test:import": "node test/import-smoke.mjs",
    "test:contents": "node test/package-contents-smoke.mjs",
    "test:presentation": "node test/presentation-export-smoke.mjs",
    "test:template-library": "node test/template-library-smoke.mjs",
    "test:template-creator": "node test/template-creator-smoke.mjs",
    "test:default-template-library": "node test/default-template-library-smoke.mjs",
    "test:pack": "node test/package-skill-exclusion-smoke.mjs && node test/packed-install-smoke.mjs"
  },
  "bundledDependencies": [
    "@officer/embedded-fonts",
    "@officer/walnut",
    "skia-canvas"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "skia-canvas"
    ]
  }
}
